rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper checks
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check if the authenticated user is a registered administrator.
    // Falls back to checking if the config exists; if it doesn't, we allow the bootstrap setup.
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/admin_settings/config) &&
             (
               request.auth.token.email.lower() in get(/databases/$(database)/documents/admin_settings/config).data.adminEmails ||
               request.auth.token.email in get(/databases/$(database)/documents/admin_settings/config).data.adminEmails
             );
    }

    // Documents collection rules
    match /documents/{documentId} {
      allow get: if true; // Allow unauthenticated retrieval of a specific rated document for satisfaction feedback surveys
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      // Allow administrator updates OR unauthenticated updates of ONLY serviceRating and updatedAt fields
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['serviceRating', 'updatedAt']));
    }

    match /outgoing_documents/{documentId} {
      allow read, write: if isAdmin();
    }

    match /outgoingDocuments/{documentId} {
      allow read, write: if isAdmin();
    }

    match /counters/{counterId} {
      allow read, write: if isAdmin();
    }

    // Config settings rules
    match /admin_settings/{settingsId} {
      // Any authenticated user should be able to read config to resolve their admin status
      allow read: if isSignedIn();
      // Only existing admins can write or modify the admin settings config, or let the first run configure it if it doesn't exist yet
      allow write: if isAdmin() || (!exists(/databases/$(database)/documents/admin_settings/config));
    }

    match /admin_settings/{settingsId}/{subCollection=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
