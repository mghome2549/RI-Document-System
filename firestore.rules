rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to authenticated users for both document collections
    match /documents/{documentId} {
      allow get: if true; // Allow unauthenticated retrieval of a specific rated document
      allow list: if request.auth != null;
      allow create, delete: if request.auth != null;
      // Allow authenticated write, OR unauthenticated update of ONLY serviceRating and updatedAt fields
      allow update: if (request.auth != null) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['serviceRating', 'updatedAt']));
    }
    match /outgoing_documents/{documentId} {
      allow read, write: if request.auth != null;
    }
    match /outgoingDocuments/{documentId} {
      allow read, write: if request.auth != null;
    }
    match /counters/{counterId} {
      allow read, write: if request.auth != null;
    }
    match /admin_settings/{settingsId} {
      allow read, write: if request.auth != null;
    }
    match /admin_settings/{settingsId}/{subCollection=**} {
      allow read, write: if request.auth != null;
    }
  }
}
